                    end
    
                    Flags[Cfg.Flag] = IsTable and Selected or Selected[1]
                    Cfg.Callback(Flags[Cfg.Flag])
                end
    
                local List = setmetatable(Cfg, Library)
                List:SetupElement(Cfg.Default)
