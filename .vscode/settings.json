{
  "luau-lsp.sourcemap.rojoProjectFile": "default.project.json",
  "luau-lsp.sourcemap.enabled": true,
  "luau-lsp.sourcemap.sourcemapFile": "sourcemap.json",

  "luau-lsp.types.definitionFiles": [".vscode/exploitTypes.d.luau"],
  "luau-lsp.types.robloxSecurityLevel": "RobloxScriptSecurity",

  "luau-lsp.plugin.maximumRequestBodySize": "1gb",
  "luau-lsp.plugin.enabled": true,

  "luau-lsp.diagnostics.strictDatamodelTypes": false,
  "luau-lsp.diagnostics.workspace": true,

  "luau-lsp.sourcemap.autogenerate": true,
  "luau-lsp.sourcemap.includeNonScripts": true,

  "luau-lsp.ignoreGlobs": [
    "Distribution/**",
    ".vscode/**",
    ".lune/**",
    "Build/**",
    "Src/Packages/**"
  ],

  "luau-lsp.bytecode.vectorCtor": "new",
  "luau-lsp.bytecode.vectorLib": "Vector3",
  "luau-lsp.bytecode.vectorType": "Vector3",

  "stylua.verify": true,

  "[luau]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua"
  },

  "files.associations": {
    "**/Src/Spy/Hooks/Actors/*": "luau",
    "**/Src/Spy/Actors/*": "luau",
    //"**/Src/Utils/CodeGen/SessionHTMLView.txt": "html"
  },
  "stylua.targetReleaseVersion": "latest",
  
  // Live Server settings
  "liveServer.settings.port": 5501,
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.CustomBrowser": "chrome",
  "liveServer.settings.NoBrowser": true,
  "liveServer.settings.ignoreFiles": [
    ".vscode/**",
    "**/*.json",
    "**/*.md"
  ],

  "selene.enabled": false
}
