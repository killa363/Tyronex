    local function getTransparency(data)
        if not data then return 0 end
        return 1 - (data.Transparency or 0) 
    end

    local function getColor(data)
        if not data then return nil end
        return data.Color or data
    end

    local function shouldCham(part)
        if not part then return false end

  
        if part.Transparency >= 0.95 then return false end

 
        if part.Size.Magnitude < 0.05 then return false end

        return true
    end

    local function makeChamClone(part, name, color3, transparency, materialName, textureKey)
        local clone = part:Clone()
        clone.Name = name
        clone:SetAttribute('__cloned', true)

        clone.Anchored = false
        clone.CanCollide = false
        clone.CanTouch = false
        clone.CanQuery = false
        clone.Massless = true

        clone.Transparency = transparency or 0
        clone.LocalTransparencyModifier = 0

        if color3 then
            clone.Color = color3
        end

        if materialName then
            clone.Material = Enum.Material[materialName]
        end

        if clone:IsA("MeshPart") then
            if materialName == "Neon" or materialName == "Glass" then
                clone.TextureID = "" 
            elseif materialName == "ForceField" and textureKey then
                clone.TextureID = Globals.Assets.Textures[textureKey] or ""
            end
        end
        clone.Parent = part.Parent
        clone.CFrame = part.CFrame

        local wc = Instance.new('WeldConstraint')
        wc.Part0 = clone
        wc.Part1 = part
        wc.Parent = clone

        return clone
    end

