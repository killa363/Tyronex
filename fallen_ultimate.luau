            local bases = workspace:FindFirstChild("Bases")
            local stored_xray_parts = {}

            local valid_xray = {
                "Wall",
                "Foundation",
                "Floor",
                "Doorway",
                "^Window"
            }

            local function is_valid_xray(part)
                if not part:IsA("BasePart") then return end
                if part.Transparency >= 1 then return end
                if stored_xray_parts[part] then return end

                local name = part.Parent and part.Parent.Name
                if not name then return end

                for _, match in ipairs(valid_xray) do
                    if string.match(name, match) then
                        return part.Transparency
                    end
                end
            end

            local function apply_xray(part)
                local old = is_valid_xray(part)
                if old then
                    stored_xray_parts[part] = old
                    part.Transparency = flags.xray_transparency
                end
            end

            local function enable_xray()
                if not bases then return end
                for _, v in ipairs(bases:GetDescendants()) do
                    apply_xray(v)
                end
            end

            local function disable_xray()
                for part, old in pairs(stored_xray_parts) do
                    if part then
                        part.Transparency = old
                    end
                end
                table.clear(stored_xray_parts)
            end

            local function update_xray()
                local state = flags.xray and flags.xray_keybind.Active

                if state then
                    enable_xray()
                else
                    disable_xray()
                end
            end
