                                visPart = p
                                break
                            end
                            local cache = LastVisiblePart and LastVisiblePart[character]

                            if cache and cache.Part and cache.Time and (now - cache.Time < VisibleHoldTime) then
                                visPart = cache.Part
                                break
                            end
                        end
                    end
                    Object.CoreInformation = {
                        Visible = visPart ~= nil,
                        VisiblePart = visPart,
                        Root = root,
                        RootPosition = root.Position,
                        OnScreen = on,
                    }
                end
            end

