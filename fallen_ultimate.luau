            local Workspace = game:GetService("Workspace")
            
            local stored_damage_parts = {}
            local stored_fire_parts = {}
            local stored_trap_parts = {}
            
            local function insert_part(tbl, part, parent)
                tbl[part] = parent
                part.Destroying:Once(function()
                    tbl[part] = nil
                end)
            end
            
            local function restore_table(tbl)
                for part, parent in tbl do
                    if part and part.Parent == CoreGui then
                        part.Parent = parent
                    end
                end
                table.clear(tbl)
            end
            
            local function scan_damage()
                for _, v in Workspace:GetDescendants() do
                    if v:IsA("BasePart") and v.Name == "DamagePart" and not stored_damage_parts[v] then
                        insert_part(stored_damage_parts, v, v.Parent)
                        v.Parent = CoreGui
                    end
                end
