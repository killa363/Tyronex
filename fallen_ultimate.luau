                        if hudVisible then
                            hudVisible = false
                            lastPlayer = nil
                            Window.SetTargetStatsVisibility(false)
                        end
                        return
                    end
            
                    local now = tick()
                    if now - lastHUDTick < 0.05 then return end
                    lastHUDTick = now
            
                    local targetChar = Targeting and Targeting.TargetCharacter
            
                    if not targetChar or not targetChar.Parent then
                        if hudVisible then
